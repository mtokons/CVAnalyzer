// CV Creator - Prisma Schema
// Supports multi-source profile aggregation, AI-generated CVs, and job application tracking

generator client {
  provider      = "prisma-client-js"
  // Include the Linux/OpenSSL targets used by Cloud Run (Firebase App Hosting)
  // and Vercel serverless (Amazon Linux), plus the local native target so the
  // engine resolves in every environment.
  binaryTargets = ["native", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User & Auth ──────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  passwordHash  String?
  role          String    @default("MEMBER") // SUPER_ADMIN | ADMIN | MEMBER | EMPLOYER
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  profile       Profile?
  jobs          Job[]
  cvDocuments   CVDocument[]
  coverLetters  CoverLetter[]
  applications  Application[]
  credentials   PortalCredential[]
  sessions      Session[]
  accounts      Account[]
  gmailAccount  GmailAccount?
  emails        EmailMessage[]
  activityLogs  ActivityLog[]
  ownedProjects Project[]      @relation("ProjectOwner")
  partnerProjects Project[]    @relation("ProjectPartner")
  posts         Post[]
  comments      PostComment[]
}

// ─── Activity Log (Admin Audit Trail) ────────────────────────────────────────

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  email     String?  // attempted/affected email (kept even if user is deleted or never existed)
  action    String   // LOGIN_SUCCESS | LOGIN_FAILED | LOGOUT | REGISTER | PASSWORD_CHANGED | ERROR | ...
  category  String   @default("AUTH") // AUTH | ACCOUNT | ERROR | ADMIN | SYSTEM
  status    String   @default("SUCCESS") // SUCCESS | FAILURE
  message   String?
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
  @@index([action])
  @@index([category])
  @@index([status])
  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Profile (Aggregated Master Profile) ─────────────────────────────────────

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName    String?
  email       String?
  phone       String?
  location    String?
  website     String?
  linkedin    String?
  github      String?
  summary     String?  @db.Text

  preferredTemplate String? @default("berlin-modern")

  // Public sharing: profile is public unless isPublic=false. privateFields lists
  // which field keys are hidden from other users (e.g. ["phone","email"]).
  isPublic      Boolean @default(true)
  privateFields Json    @default("[]")

  experience     Json  @default("[]")
  education      Json  @default("[]")
  skills         Json  @default("[]")
  certifications Json  @default("[]")
  languages      Json  @default("[]")
  projects       Json  @default("[]")
  awards         Json  @default("[]")
  publications   Json  @default("[]")

  sources     ProfileSource[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Profile Source ───────────────────────────────────────────────────────────

// ─── Community Timeline (Posts & Comments) ───────────────────────────────────

model Post {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  text      String        @db.Text
  imageData String?       @db.Text // compressed base64 data URL
  comments  PostComment[]
  createdAt DateTime      @default(now())

  @@index([createdAt])
  @@index([userId])
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  text      String   @db.Text
  imageData String?  @db.Text // compressed base64 data URL
  createdAt DateTime @default(now())

  @@index([postId])
}

model ProfileSource {
  id          String      @id @default(cuid())
  profileId   String
  profile     Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)

  sourceType  SourceType
  sourceName  String
  rawContent  String      @db.Text
  parsedData  Json        @default("{}")
  fileUrl     String?
  status      ParseStatus @default(PENDING)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

enum SourceType {
  LINKEDIN
  MONSTER
  PDF_UPLOAD
  WORD_UPLOAD
  TEXT_UPLOAD
  MANUAL
  URL
}

enum ParseStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ─── Job Posting ──────────────────────────────────────────────────────────────

model Job {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  title           String
  company         String
  location        String?
  jobType         String?
  salary          String?
  description     String    @db.Text
  requirements    Json      @default("[]")
  keywords        Json      @default("[]")
  portalUrl       String?
  portalName      String?
  applicationUrl  String?

  atsScore        Int?
  matchedSkills   Json      @default("[]")
  missingSkills   Json      @default("[]")

  status          JobStatus @default(SAVED)
  notes           String?   @db.Text
  appliedAt       DateTime?

  cvDocuments     CVDocument[]
  coverLetters    CoverLetter[]
  application     Application?
  emails          EmailMessage[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

enum JobStatus {
  SAVED
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

// ─── Generated CV ─────────────────────────────────────────────────────────────

model CVDocument {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId       String?
  job         Job?      @relation(fields: [jobId], references: [id])

  title       String
  template    String    @default("modern")
  content     Json
  htmlContent String?   @db.Text
  pdfUrl      String?
  aiModel     String?
  prompt      String?   @db.Text
  version     Int       @default(1)
  isActive    Boolean   @default(true)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── Cover Letter ─────────────────────────────────────────────────────────────

model CoverLetter {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId       String?
  job         Job?      @relation(fields: [jobId], references: [id])

  title       String
  content     String    @db.Text
  tone        String    @default("professional")
  aiModel     String?
  version     Int       @default(1)
  isActive    Boolean   @default(true)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── Job Application ──────────────────────────────────────────────────────────

model Application {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId         String      @unique
  job           Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)

  formData      Json        @default("{}")
  fillStatus    FillStatus  @default(PENDING)
  fillLog       Json        @default("[]")
  screenshotUrl String?
  verifiedAt    DateTime?
  submittedAt   DateTime?
  notes         String?     @db.Text

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

enum FillStatus {
  PENDING
  FILLING
  AWAITING_REVIEW
  APPROVED
  SUBMITTED
  FAILED
}

// ─── Portal Credentials ───────────────────────────────────────────────────────

model PortalCredential {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  portalName  String
  portalUrl   String
  username    String
  password    String
  extraFields Json      @default("{}")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, portalName])
}

// ─── Gmail Connection & Email Tracking ────────────────────────────────────────

model GmailAccount {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  email        String
  accessToken  String    @db.Text // AES-256-GCM encrypted
  refreshToken String    @db.Text // AES-256-GCM encrypted
  expiryDate   DateTime?
  scope        String?
  lastSyncedAt DateTime?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model EmailMessage {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId          String?
  job            Job?      @relation(fields: [jobId], references: [id], onDelete: SetNull)

  gmailId        String    @unique
  threadId       String?
  fromEmail      String?
  fromName       String?
  toEmail        String?
  subject        String?   @db.Text
  snippet        String?   @db.Text
  receivedAt     DateTime?

  category       EmailCategory @default(OTHER)
  isFromEmployer Boolean   @default(false)

  createdAt      DateTime  @default(now())

  @@index([userId])
  @@index([jobId])
}

enum EmailCategory {
  INTERVIEW
  OFFER
  REJECTION
  ACKNOWLEDGEMENT
  OTHER
}

// ─── Project Management (Expert Sourcing for Tenders) ─────────────────────────
// We act as an indirect (sometimes direct) partner: we are selected for the
// technical & financial quote of national/international expert profiles, build
// standardised CVs, rate candidates, and report back to the partner.

model Project {
  id            String        @id @default(cuid())
  serial        String        @unique // PRJ-2026-0001
  name          String
  partnerType   PartnerType   @default(INDIRECT)
  status        ProjectStatus @default(DRAFT)

  partnerName   String?       // upstream partner / client we report to
  country       String?
  description   String?       @db.Text
  requirements  String?       @db.Text
  ratingGuide   String?       @db.Text // project rating guideline for CV analysis
  currency      String        @default("EUR") // primary currency
  deadline      DateTime?

  ownerId       String
  owner         User          @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  partnerUserId String?
  partnerUser   User?         @relation("ProjectPartner", fields: [partnerUserId], references: [id], onDelete: SetNull)

  candidates    ProjectCandidate[]
  reports       ProjectReport[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([ownerId])
}

enum PartnerType {
  DIRECT
  INDIRECT
}

enum ProjectStatus {
  DRAFT
  QUOTING
  SUBMITTED
  WON
  LOST
  CLOSED
}

model Candidate {
  id            String     @id @default(cuid())
  serial        String     @unique // CAND-2026-00001
  fullName      String
  email         String?
  phone         String?
  country       String?
  nationality   String?
  profession    String?
  category      String?    // categorised per project rating guideline
  rating        Int?       // 0-100 analysis score
  source        CandidateSource @default(ONLINE)

  // Currency: experts bill in various currencies; we convert to EUR.
  rateAmount    Float?     // expert's own rate
  rateCurrency  String     @default("EUR")
  rateUnit      String     @default("day") // day | hour | month

  // Original uploaded CV (online generated or offline scanned) + standardised
  originalCvUrl String?
  cvFormat      String?    // NATIONAL | INTERNATIONAL
  standardCvUrl String?
  standardCvId  String?    // links to CVDocument when generated online
  notes         String?    @db.Text
  basicInfo     Json       @default("{}")

  projects      ProjectCandidate[]

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([source])
  @@index([category])
}

enum CandidateSource {
  ONLINE  // CV available/built in the portal
  OFFLINE // scanned copy uploaded, not natively in portal
}

model ProjectCandidate {
  id            String    @id @default(cuid())
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  candidateId   String
  candidate     Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  // We pay the expert (cost) and the partner pays us (bill). Each may be in a
  // different currency; converted to EUR for reporting.
  expertRate    Float?
  expertCurrency String   @default("EUR")
  partnerRate   Float?
  partnerCurrency String  @default("EUR")
  expertRateEur Float?
  partnerRateEur Float?
  marginEur     Float?

  status        String    @default("PROPOSED") // PROPOSED | SHORTLISTED | SUBMITTED | ACCEPTED | REJECTED

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([projectId, candidateId])
  @@index([projectId])
}

model ProjectReport {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  summary     String?  @db.Text
  payload     Json     @default("{}") // snapshot of candidates + rates
  createdAt   DateTime @default(now())
}

// Live exchange rates cached daily (base = EUR).
model ExchangeRate {
  code      String   @id // ISO 4217, e.g. USD
  rate      Float    // 1 EUR = rate * code
  fetchedAt DateTime @default(now())
}
